# Local-only example values. Replace token, database password, and cookie secret before any shared or cloud deploy.
DOCFERRY_SERVICE_NAME=docferry-share
DOCFERRY_VERSION=0.0.6
DOCFERRY_ENV=development
DOCFERRY_API_TOKEN=dev-token
DOCFERRY_TOKEN_HASH_SECRET=dev
DOCFERRY_INSTALL_HASH_SECRET=dev-install
DOCFERRY_BLIND_INDEX_SECRET=dev-blind-index
DOCFERRY_DEFAULT_ACTIVE_SHARE_LIMIT=5
DOCFERRY_CLOUD_CLAIM_ENABLED=true
DOCFERRY_CLOUD_CLAIM_IP_HOUR_LIMIT=60
DOCFERRY_CLOUD_CLAIM_INSTALL_HOUR_LIMIT=10
DOCFERRY_MASTER_KEY_B64=
DOCFERRY_ENCRYPTION_KEY_ID=v1
DOCFERRY_ENCRYPTION_REQUIRED=false
DOCFERRY_PUBLIC_BASE_URL=http://127.0.0.1:8787
DOCFERRY_TRUSTED_PROXY_HOSTS=
DOCFERRY_DATABASE_URL=postgresql+psycopg://docferry:docferry@127.0.0.1:5432/docferry
DOCFERRY_COOKIE_SECRET=change-me-before-deploy
DOCFERRY_PASSWORD_FAILED_LIMIT=8
DOCFERRY_PASSWORD_FAILED_WINDOW_SECONDS=600
DOCFERRY_OBJECT_STORAGE_ROOT=./.local/object-storage
DOCFERRY_ASSET_MAX_BYTES=10485760
DOCFERRY_ASSET_MAX_PER_SHARE=50
DOCFERRY_ASSET_OWNER_QUOTA_BYTES=1073741824
DOCFERRY_SNAPSHOT_MAX_DB_BYTES=262144
DOCFERRY_LOG_LEVEL=INFO
DOCFERRY_LOG_FORMAT=json
DOCFERRY_BACKUP_ROOT=/root/backups/docferry
DOCFERRY_BACKUP_RETENTION_DAYS=30
DOCFERRY_BACKUP_KEEP_LAST=7
DOCFERRY_ASSET_GC_DAYS=7
DOCFERRY_ACCESS_EVENT_RETENTION_DAYS=90
DOCFERRY_MAINTENANCE_ALERT_WEBHOOK_URL=
DOCFERRY_MAINTENANCE_ALERT_ON=failure
