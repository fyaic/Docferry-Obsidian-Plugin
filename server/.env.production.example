# Production example values. Copy to .env.production on the server and replace every secret.
# Do not commit .env.production.

DOCFERRY_SERVICE_NAME=docferry-share
DOCFERRY_VERSION=0.0.1
DOCFERRY_ENV=production
DOCFERRY_PUBLIC_BASE_URL=https://your-docferry-server.example.com

DOCFERRY_API_TOKEN=<replace-with-long-random-token>
DOCFERRY_TOKEN_HASH_SECRET=
DOCFERRY_DEFAULT_ACTIVE_SHARE_LIMIT=10
DOCFERRY_COOKIE_SECRET=<replace-with-long-random-secret>
DOCFERRY_POSTGRES_PASSWORD=<replace-with-long-random-db-password>
DOCFERRY_POSTGRES_PORT=55432
DOCFERRY_DATABASE_URL=postgresql+psycopg://docferry:<replace-with-long-random-db-password>@127.0.0.1:55432/docferry

# Encrypted-at-rest storage. Generate a 32-byte base64 key, for example:
# python -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
DOCFERRY_MASTER_KEY_B64=
DOCFERRY_ENCRYPTION_KEY_ID=v1
DOCFERRY_ENCRYPTION_REQUIRED=true

# Password page brute-force guard. Set limit <= 0 to disable.
DOCFERRY_PASSWORD_FAILED_LIMIT=8
DOCFERRY_PASSWORD_FAILED_WINDOW_SECONDS=600

# Object storage for published assets and large snapshots.
DOCFERRY_OBJECT_STORAGE_ROOT=/cos-data/docferry
DOCFERRY_ASSET_MAX_BYTES=10485760
DOCFERRY_ASSET_MAX_PER_SHARE=50
DOCFERRY_ASSET_OWNER_QUOTA_BYTES=1073741824

# Markdown / HTML snapshots larger than this are stored as private object assets.
DOCFERRY_SNAPSHOT_MAX_DB_BYTES=262144

# Structured application logs. Do not log request query strings, tokens, cookies, or passwords.
DOCFERRY_LOG_LEVEL=INFO
DOCFERRY_LOG_FORMAT=json

# Maintenance defaults used by scripts/run_maintenance.py.
DOCFERRY_BACKUP_ROOT=/root/backups/docferry
DOCFERRY_BACKUP_RETENTION_DAYS=30
DOCFERRY_BACKUP_KEEP_LAST=7
DOCFERRY_ASSET_GC_DAYS=7
DOCFERRY_ACCESS_EVENT_RETENTION_DAYS=90

# Optional webhook for maintenance failure alerts. Leave empty until the notification target is decided.
DOCFERRY_MAINTENANCE_ALERT_WEBHOOK_URL=
DOCFERRY_MAINTENANCE_ALERT_ON=failure
